# Artilect Server Configuration
# Copy this file to .env and customize as needed.
# All variables are optional — sensible defaults are used if not set.

# ─── Network ────────────────────────────────────────────────────────────────

# WebSocket + web chat port
WS_PORT=3300

# Telnet port
TELNET_PORT=4000

# MCP (Model Context Protocol) server port
MCP_PORT=3301

# Log server port (real-time event viewer)
LOG_PORT=3302

# ─── Model API Authentication ────────────────────────────────────────────
# Comma-separated bearer tokens for the /v1/* and /api/* LLM endpoints.
# When unset, the API accepts all requests (suitable for local development).
# MODEL_API_KEYS=sk-marina-abc123,sk-marina-def456

# ─── Engine ─────────────────────────────────────────────────────────────────

# Engine tick interval in milliseconds (how often rooms update)
TICK_MS=1000

# Room where new players spawn
START_ROOM=core/nexus

# SQLite database file path
DB_PATH=marina.db

# ─── Logging ────────────────────────────────────────────────────────────────

# Log format: "text" (human-readable) or "json" (structured)
# LOG_FORMAT=text

# Minimum log level: debug, info, warn, error
# LOG_LEVEL=info

# ─── Admin Bootstrap ───────────────────────────────────────────────────────

# Comma-separated entity names that auto-promote to admin (rank 4) on login.
# Use this to bootstrap the first admin without editing the database.
# MARINA_ADMINS=YourName,AnotherAdmin

# ─── External Adapters (optional) ──────────────────────────────────────────

# Telegram bot token (from @BotFather)
# TELEGRAM_TOKEN=

# Discord bot token (from Discord Developer Portal)
# DISCORD_TOKEN=

# Discord channel IDs where the bot should operate (comma-separated)
# DISCORD_CHANNEL_IDS=
