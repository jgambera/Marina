{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@engine/*": ["src/engine/*"],
      "@world/*": ["src/world/*"],
      "@net/*": ["src/net/*"],
      "@auth/*": ["src/auth/*"],
      "@persistence/*": ["src/persistence/*"],
      "@rooms/*": ["rooms/*"]
    },
    "types": ["bun"]
  },
  "include": ["src/**/*.ts", "rooms/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
